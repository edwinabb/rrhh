// Fase 0 — Fundaciones. Ver docs/superpowers/specs/2026-07-07-fase0-fundaciones-design.md
// para las decisiones detrás de este esquema (RLS, roles nativos de Postgres, vistas por rol).

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [pgcrypto]
}

// ---------------------------------------------------------------------------
// Multi-tenancy e identidad
// ---------------------------------------------------------------------------

model Tenant {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruc            String   @unique @db.VarChar(11)
  razonSocial    String   @map("razon_social")
  nombreComercial String? @map("nombre_comercial")
  direccionFiscal String? @map("direccion_fiscal")
  estado         String   @default("activo") @db.VarChar(20) // activo | suspendido
  createdAt      DateTime @default(now()) @map("created_at")

  sedes              Sede[]
  users              User[]
  roles              Role[]
  employees          Employee[]
  auditLogs          AuditLog[]

  // Fase 2 — Asistencia
  marcaciones             Marcacion[]
  geofences               Geofence[]
  justificaciones         Justificacion[]
  horasExtras             HorasExtra[]
  asistenciaResumenes     AsistenciaResumen[]
  configuracionAsistencia ConfiguracionAsistencia?

  // Fase 3 — Documental
  documentos          Document[]
  documentoVersiones  DocumentVersion[]

  // Fase 4 — ATS
  vacantes       Vacante[]
  candidatos     Candidato[]
  candidatoNotas CandidatoNota[]

  @@map("tenant")
}

model Sede {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  nombre    String
  direccion String?
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]

  // Fase 2 — Asistencia
  marcaciones Marcacion[]
  geofences   Geofence[]

  // Fase 4 — ATS
  vacantes Vacante[]

  @@index([tenantId])
  @@map("sede")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String    @unique @db.VarChar(255) // normalizar a minúsculas en la capa de aplicación
  passwordHash String    @map("password_hash")
  estado       String    @default("activo") @db.VarChar(20) // activo | bloqueado
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles    UserRole[]
  employee Employee?
  auditLogs AuditLog[]

  @@index([tenantId])
  @@map("app_user")
}

// ---------------------------------------------------------------------------
// RBAC
// ---------------------------------------------------------------------------

model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String? @map("tenant_id") @db.Uuid // null = plantilla de sistema
  nombre      String
  descripcion String?
  esSistema   Boolean @default(false) @map("es_sistema")

  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@index([tenantId])
  @@map("role")
}

model Permission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique // ej. employee.salary.read
  descripcion String?
  esSensible  Boolean @default(false) @map("es_sensible") // flag para columnas salud/ingresos

  roles RolePermission[]

  @@map("permission")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_role")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

// ---------------------------------------------------------------------------
// Trabajador (esqueleto — se extiende en Fase 1)
// ---------------------------------------------------------------------------

model Employee {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  sedeId          String   @map("sede_id") @db.Uuid
  userId          String?  @unique @map("user_id") @db.Uuid
  managerId       String?  @map("manager_id") @db.Uuid
  tipoDocumento   String   @map("tipo_documento") @db.VarChar(2) // codigo Tabla 3 SUNAT
  numeroDocumento String   @map("numero_documento") @db.VarChar(15)
  nombres         String
  apellidos       String
  estado          String   @default("activo") @db.VarChar(20) // activo | cesado
  createdAt       DateTime @default(now()) @map("created_at")

  tenant  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sede    Sede      @relation(fields: [sedeId], references: [id])
  user    User?     @relation(fields: [userId], references: [id])
  manager Employee? @relation("EmployeeManager", fields: [managerId], references: [id])
  reports Employee[] @relation("EmployeeManager")

  contratos            Contrato[]
  cuentasBancarias      CuentaBancaria[]
  regimenesPensionarios RegimenPensionario[]
  planillaDetalles      PlanillaDetalle[]
  liquidacion           Liquidacion?

  // Fase 2 — Asistencia
  marcaciones         Marcacion[]
  justificaciones     Justificacion[]
  horasExtras         HorasExtra[]
  asistenciaResumenes AsistenciaResumen[]

  // Fase 3 — Documental
  documentos Document[]

  // Fase 4 — ATS: candidato contratado que se convirtió en trabajador (D.Leg. 728)
  candidaturas Candidato[]

  @@unique([tenantId, tipoDocumento, numeroDocumento])
  @@index([tenantId])
  @@index([managerId])
  @@map("employee")
}

// ---------------------------------------------------------------------------
// Fase 1 — Nómina
// ---------------------------------------------------------------------------

model Contrato {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId          String    @map("employee_id") @db.Uuid
  regimenLaboral      String    @map("regimen_laboral") @db.VarChar(20) // general | mype | agrario
  regimenLaboralSunat String    @map("regimen_laboral_sunat") @db.VarChar(2) // codigo Tabla 33
  tipoTrabajadorSunat String    @map("tipo_trabajador_sunat") @db.VarChar(2) // codigo Tabla 8
  tipoContrato        String    @map("tipo_contrato") @db.VarChar(30)
  tipoContratoSunat   String    @map("tipo_contrato_sunat") @db.VarChar(2) // codigo Tabla 12
  fechaInicio         DateTime  @map("fecha_inicio") @db.Date
  fechaFin            DateTime? @map("fecha_fin") @db.Date // null = indeterminado
  jornada             Json // horas/dias pactados
  remuneracionBasica   Decimal  @map("remuneracion_basica") @db.Decimal(10, 2)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("contrato")
}

model CuentaBancaria {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId  String  @map("employee_id") @db.Uuid
  banco       String  @db.VarChar(3) // codigo Tabla 36
  tipoCuenta  String  @map("tipo_cuenta") @db.VarChar(20)
  numero      String  @db.VarChar(20)
  cci         String? @db.VarChar(20)
  esPrincipal Boolean @default(true) @map("es_principal")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("cuenta_bancaria")
}

model RegimenPensionario {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId      String   @map("employee_id") @db.Uuid
  sistema         String   @db.VarChar(10) // afp | onp
  administradora  String?  @db.VarChar(20) // nullable, solo afp: integra/horizonte/profuturo/prima/habitat
  tipoComision    String?  @map("tipo_comision") @db.VarChar(10) // flujo | mixta, nullable
  codigoSunat     String   @map("codigo_sunat") @db.VarChar(2) // codigo Tabla 11
  fechaAfiliacion DateTime @map("fecha_afiliacion") @db.Date

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("regimen_pensionario")
}

model Concepto {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String? @map("tenant_id") @db.Uuid // null = catálogo global
  codigo         String  @db.VarChar(20)
  codigoSunat    String  @map("codigo_sunat") @db.VarChar(4) // 4 digitos, Tabla 22
  nombre         String
  tipo           String  @db.VarChar(10) // ingreso | descuento
  esRemunerativo Boolean @map("es_remunerativo")
  afectoA        Json    @map("afecto_a") // essalud, onp, afp, quinta, cts, grati (derivado de Tabla 22)

  @@unique([tenantId, codigo])
  @@index([codigoSunat])
  @@map("concepto")
}

model Planilla {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  periodo    String    @db.VarChar(7) // YYYY-MM
  estado     String    @default("registrado") @db.VarChar(20) // registrado | procesado | cerrado
  cerradoAt  DateTime? @map("cerrado_at")

  detalles    PlanillaDetalle[]
  horasExtras HorasExtra[] // Fase 2 — horas extra exportadas a esta planilla

  @@unique([tenantId, periodo])
  @@index([tenantId])
  @@map("planilla")
}

model PlanillaDetalle {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planillaId         String  @map("planilla_id") @db.Uuid
  employeeId         String  @map("employee_id") @db.Uuid
  conceptosCalculados Json   @map("conceptos_calculados")
  netoPagar          Decimal @map("neto_pagar") @db.Decimal(10, 2)

  planilla Planilla @relation(fields: [planillaId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([planillaId])
  @@index([employeeId])
  @@map("planilla_detalle")
}

model Provision {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String   @map("tenant_id") @db.Uuid
  periodo  String   @db.VarChar(7)
  tipo     String   @db.VarChar(20) // cts | gratificacion | vacaciones
  monto    Decimal  @db.Decimal(10, 2)

  @@index([tenantId, periodo])
  @@map("provision")
}

model Liquidacion {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String   @unique @map("employee_id") @db.Uuid
  fechaCese    DateTime @map("fecha_cese") @db.Date
  componentes  Json // cts_trunca, grati_trunca, vacaciones_truncas
  generadoAt   DateTime @default(now()) @map("generado_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("liquidacion")
}

// ---------------------------------------------------------------------------
// Motor de parámetros normativos (nacional, no por tenant)
// ---------------------------------------------------------------------------

model NormativeParameter {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codigo         String    @db.VarChar(64) // UIT, RMV, ESSALUD_TASA...
  valor          Json // escalar o estructura (tramos)
  vigenciaDesde  DateTime  @map("vigencia_desde") @db.Date
  vigenciaHasta  DateTime? @map("vigencia_hasta") @db.Date // null = vigente
  descripcion    String?
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([codigo, vigenciaDesde])
  @@map("normative_parameter")
}

// ---------------------------------------------------------------------------
// Auditoría inmutable (poblada por trigger de Postgres, ver migración RLS)
// ---------------------------------------------------------------------------

model AuditLog {
  id                BigInt   @id @default(autoincrement())
  tenantId          String?  @map("tenant_id") @db.Uuid
  userId            String?  @map("user_id") @db.Uuid // null = acción de sistema
  tabla             String
  registroId        String?  @map("registro_id") @db.Uuid
  accion            String   @db.VarChar(10) // INSERT | UPDATE | DELETE
  valoresAnteriores Json?    @map("valores_anteriores")
  valoresNuevos     Json?    @map("valores_nuevos")
  ipOrigen          String?  @map("ip_origen") @db.Inet
  userAgent         String?  @map("user_agent")
  requestId         String?  @map("request_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, tabla, registroId])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// Fase 2 — Asistencia
// Ver docs/superpowers/specs/2026-07-14-fase2-asistencia-design.md.
// La tabla "marcacion" es append-only (SUNAFIL D.Leg. 910): la migración
// 20260714000000_fase2_asistencia no otorga UPDATE/DELETE a ningún rol de
// aplicación y una política RESTRICTIVE bloquea UPDATE/DELETE a nivel de RLS.
// Las correcciones se registran como nuevas marcaciones o justificaciones.
// ---------------------------------------------------------------------------

enum TipoMarcacion {
  ENTRADA
  SALIDA
  JUSTIFICACION

  @@map("tipo_marcacion")
}

enum TipoIdentificacion {
  HUELLA
  FACIAL
  PIN
  QR
  MANUAL

  @@map("tipo_identificacion")
}

enum MotivoJustificacion {
  TARDANZA // entrada tardía
  FALTA // no se presentó
  PERMISO // permiso justificado
  LICENCIA // licencia personal o médica
  CALAMIDAD // calamidad doméstica
  EVENTO_EMPRESA // evento/reunión de empresa
  TELETRABAJO // día de teletrabajo autorizado

  @@map("motivo_justificacion")
}

enum EstadoJustificacion {
  PENDIENTE
  APROBADA
  RECHAZADA

  @@map("estado_justificacion")
}

enum TipoHoraExtra {
  DIARIAS // exceso sobre el tope diario (>8h/día por defecto)
  SEMANALES // exceso sobre el tope semanal (>48h/semana por defecto)

  @@map("tipo_hora_extra")
}

// Registro append-only de cada marcación (entrada/salida/justificación).
model Marcacion {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  employeeId String @map("employee_id") @db.Uuid
  sedeId     String @map("sede_id") @db.Uuid

  tipo      TipoMarcacion
  timestamp DateTime      @default(now()) // momento del evento de marcación

  // Geofencing
  latitud             Float?
  longitud            Float?
  distanciaSedeMetros Float?  @map("distancia_sede_metros") // calculada contra el geofence al registrar
  ubicacionValidada   Boolean @default(false) @map("ubicacion_validada")

  // Biometría
  tipoIdentificacion TipoIdentificacion? @map("tipo_identificacion")
  scoreBiometria     Float?              @map("score_biometria") // confianza del match: 0.0 a 1.0
  dispositivoId      String?             @map("dispositivo_id") // dispositivo biométrico de origen

  // Justificación embebida (solo si tipo = JUSTIFICACION)
  motivoJustificacion MotivoJustificacion? @map("motivo_justificacion")
  documentoAdjuntoUrl String?              @map("documento_adjunto_url")
  descripcion         String?              @db.Text

  // Bloqueos y autorización pre-aprobada (se fija al crear, nunca por UPDATE)
  bloqueado            Boolean   @default(false)
  motivoBloqueo        String?   @map("motivo_bloqueo") // ej. "Fuera de sede y sin autorización"
  requiereAutorizacion Boolean   @default(false) @map("requiere_autorizacion")
  autorizadoPor        String?   @map("autorizado_por") @db.Uuid // user id del gerente/admin que autorizó
  autorizadoEn         DateTime? @map("autorizado_en")

  // Audit trail inmutable
  creadoEn  DateTime @default(now()) @map("creado_en")
  creadoPor String   @map("creado_por") @db.Uuid // user id que registró la marcación

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  sede     Sede     @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  justificaciones Justificacion[]

  @@index([tenantId, employeeId, timestamp])
  @@index([tenantId, sedeId, timestamp])
  @@map("marcacion")
}

// Centro y radio de validación GPS por sede (un geofence por sede).
model Geofence {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  sedeId   String @map("sede_id") @db.Uuid

  latitud     Float // coordenada central
  longitud    Float // coordenada central
  radioMetros Float @default(100) @map("radio_metros")

  nombre      String // ej. "Oficina Centro Lima"
  descripcion String? @db.Text

  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sede   Sede   @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sedeId])
  @@map("geofence")
}

// Solicitud formal de justificación de falta/tardanza, con flujo de aprobación.
model Justificacion {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  employeeId  String  @map("employee_id") @db.Uuid
  marcacionId String? @map("marcacion_id") @db.Uuid // puede existir justificación sin marcación previa

  motivo MotivoJustificacion
  fecha  DateTime            @db.Date // fecha del evento justificado

  descripcion  String  @db.Text
  documentoUrl String? @map("documento_url") // adjunto (imagen/PDF del justificante)

  estado EstadoJustificacion @default(PENDIENTE)

  aprobadoPor   String?   @map("aprobado_por") @db.Uuid // user id del gerente/admin
  aprobadoEn    DateTime? @map("aprobado_en")
  motivoRechazo String?   @map("motivo_rechazo") @db.Text

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  marcacion Marcacion? @relation(fields: [marcacionId], references: [id], onDelete: SetNull)

  @@index([tenantId, employeeId, estado])
  @@index([tenantId, fecha])
  @@map("justificacion")
}

// Horas extra calculadas automáticamente a partir de las marcaciones.
model HorasExtra {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  employeeId String @map("employee_id") @db.Uuid

  fecha DateTime      @db.Date // fecha del evento (para SEMANALES: último día de la semana)
  tipo  TipoHoraExtra

  horasCalculadas Float @map("horas_calculadas") // decimales: 1.5 = 1h30m

  incluidoEnNomina Boolean @default(false) @map("incluido_en_nomina")
  planillaId       String? @map("planilla_id") @db.Uuid // planilla que consumió estas horas

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  planilla Planilla? @relation(fields: [planillaId], references: [id], onDelete: SetNull)

  @@unique([tenantId, employeeId, fecha, tipo])
  @@index([tenantId, incluidoEnNomina])
  @@map("horas_extra")
}

// Resumen diario de asistencia (desnormalizado, recalculable desde marcacion).
model AsistenciaResumen {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  employeeId String @map("employee_id") @db.Uuid

  fecha DateTime @db.Date

  horaEntrada DateTime? @map("hora_entrada")
  horaSalida  DateTime? @map("hora_salida")

  horasTrabajadas    Float @default(0) @map("horas_trabajadas")
  horasExtrasDiarias Float @default(0) @map("horas_extras_diarias")

  falta           Boolean @default(false)
  tardanzaMinutos Int     @default(0) @map("tardanza_minutos")
  justificado     Boolean @default(false)

  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, fecha])
  @@index([tenantId, fecha])
  @@map("asistencia_resumen")
}

// Parámetros de asistencia configurables por tenant (uno por tenant).
model ConfiguracionAsistencia {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @unique @map("tenant_id") @db.Uuid

  horaEntradaEstandar       String @default("08:00") @map("hora_entrada_estandar") @db.VarChar(5) // HH:mm
  horaSalidaEstandar        String @default("17:00") @map("hora_salida_estandar") @db.VarChar(5) // HH:mm
  toleranciaTardanzaMinutos Int    @default(15) @map("tolerancia_tardanza_minutos")

  requiereGeofence  Boolean @default(true) @map("requiere_geofence")
  requiereBiometria Boolean @default(false) @map("requiere_biometria")
  umbralConfianzaBiometria Float @default(0.95) @map("umbral_confianza_biometria") // score mínimo aceptado: 0.0 a 1.0

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("configuracion_asistencia")
}

// ---------------------------------------------------------------------------
// Fase 3 — Documental
// Ver docs/superpowers/specs/2026-07-14-fase3-documental-design.html.
// Los binarios viven en MinIO; aquí solo metadatos y punteros (ruta_minio).
// La eliminación es soft-delete (estado = ELIMINADO vía UPDATE): la migración
// 20260714100000_fase3_documental no otorga DELETE a ningún rol de aplicación.
// La auditoría usa el AuditLog/trigger genérico de Fase 0 (sin tabla propia).
// El control de acceso se resuelve con Permission/Role de Fase 0 (@RequirePermission).
// ---------------------------------------------------------------------------

enum TipoDocumento {
  CONTRATO
  CV
  DNI
  CERTIFICADO
  MEMO
  BOLETA
  OTRO

  @@map("tipo_documento")
}

enum EstadoDocumento {
  ACTIVO
  ELIMINADO

  @@map("estado_documento")
}

// Metadatos del documento vigente de un trabajador. El contenido de la última
// versión se referencia directamente (ruta_minio); el historial completo vive
// en DocumentVersion.
model Document {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  employeeId String @map("employee_id") @db.Uuid

  tipo          TipoDocumento
  nombreArchivo String        @map("nombre_archivo")
  mimeType      String        @map("mime_type") @db.VarChar(100)
  tamanoBytes   BigInt        @map("tamano_bytes")
  checksumMd5   String        @map("checksum_md5") @db.VarChar(32)
  rutaMinio     String        @map("ruta_minio") // clave del objeto en MinIO

  estado EstadoDocumento @default(ACTIVO)

  // LPDP (Ley 29733): consentimiento para documentos con datos personales
  requiereConsentimiento Boolean   @default(false) @map("requiere_consentimiento")
  consentimientoFecha    DateTime? @map("consentimiento_fecha")

  // Soft-delete: nunca se borra la fila, solo se marca (estado = ELIMINADO)
  eliminadoEn       DateTime? @map("eliminado_en")
  motivoEliminacion String?   @map("motivo_eliminacion") @db.Text

  subidoPor String @map("subido_por") @db.Uuid // user id que subió el documento

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  versiones DocumentVersion[]

  @@index([tenantId, employeeId, tipo])
  @@index([tenantId, estado])
  @@map("documento")
}

// Historial de versiones (append-only): cada re-subida crea una versión nueva.
model DocumentVersion {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  documentId String @map("document_id") @db.Uuid

  numeroVersion Int    @map("numero_version") // 1, 2, 3... por documento
  rutaMinio     String @map("ruta_minio")
  checksumMd5   String @map("checksum_md5") @db.VarChar(32)
  tamanoBytes   BigInt @map("tamano_bytes")

  subidoPor String   @map("subido_por") @db.Uuid
  creadoEn  DateTime @default(now()) @map("creado_en")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, numeroVersion])
  @@index([tenantId])
  @@map("documento_version")
}

// ---------------------------------------------------------------------------
// Fase 4 — ATS (reclutamiento)
// Ver docs/superpowers/specs/2026-07-14-fase4-ats-design.md.
// Los CVs de candidatos son datos personales de terceros (LPDP Ley 29733):
// la migración 20260714200000_fase4_ats solo otorga acceso a "candidato" y
// "candidato_nota" a app_rrhh/app_admin (los managers no acceden a CVs).
// ---------------------------------------------------------------------------

enum EstadoVacante {
  ABIERTA
  PAUSADA
  CERRADA

  @@map("estado_vacante")
}

enum EstadoCandidato {
  APLICADO
  REVISADO
  ENTREVISTA
  OFERTA
  RECHAZADO
  CONTRATADO

  @@map("estado_candidato")
}

model Vacante {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  titulo      String
  descripcion String @db.Text
  requisitos  Json // estructura libre: skills, experiencia, educación...

  salarioMin Decimal? @map("salario_min") @db.Decimal(10, 2)
  salarioMax Decimal? @map("salario_max") @db.Decimal(10, 2)

  estado EstadoVacante @default(ABIERTA)

  sedeId    String?   @map("sede_id") @db.Uuid // null = vacante sin sede específica
  creadoPor String    @map("creado_por") @db.Uuid // user id que creó la vacante
  cerradaEn DateTime? @map("cerrada_en")

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sede   Sede?  @relation(fields: [sedeId], references: [id], onDelete: SetNull)

  candidatos Candidato[]

  @@index([tenantId, estado])
  @@map("vacante")
}

model Candidato {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  vacanteId String @map("vacante_id") @db.Uuid

  nombreCompleto String  @map("nombre_completo")
  email          String  @db.VarChar(255) // normalizar a minúsculas en la capa de aplicación
  telefono       String? @db.VarChar(20)

  cvRutaMinio String @map("cv_ruta_minio") // clave del objeto CV en MinIO
  cvParseado  Json?  @map("cv_parseado") // resultado de extracción con Claude (null hasta parsear)

  estado EstadoCandidato @default(APLICADO)

  // LPDP (Ley 29733): consentimiento del candidato para tratar sus datos
  consentimientoLpdp Boolean @default(false) @map("consentimiento_lpdp")

  // Si se contrata (D.Leg. 728), se enlaza al trabajador creado
  employeeId String? @map("employee_id") @db.Uuid

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vacante  Vacante   @relation(fields: [vacanteId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  notas CandidatoNota[]

  @@unique([vacanteId, email])
  @@index([tenantId, estado])
  @@index([tenantId, vacanteId])
  @@map("candidato")
}

// Notas internas del equipo de reclutamiento sobre un candidato.
model CandidatoNota {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  candidatoId String @map("candidato_id") @db.Uuid

  autorId String @map("autor_id") @db.Uuid // user id del autor
  nota    String @db.Text

  creadoEn DateTime @default(now()) @map("creado_en")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidato Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  @@index([tenantId, candidatoId])
  @@map("candidato_nota")
}
